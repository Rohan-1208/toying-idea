# =============================================================================
# NEW MongoDB — Toying Idea (greenfield, NOT the old website database)
# =============================================================================
#
# Setup steps:
#   1. MongoDB Atlas → Create cluster (free tier is fine)
#   2. Database Access → Add user with read/write on this DB
#   3. Network Access → Add your IP (or 0.0.0.0/0 for dev only)
#   4. Connect → Drivers → copy connection string below
#   5. URL-encode special chars in password (@ → %40, etc.)
#   6. npm run init:db
#   7. npm run dev:full
#
# Collections created:
#   products, inventory_movements, orders, inquiries
# =============================================================================

MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=ToyingIdea"
MONGODB_DB="toying_idea"

JWT_SECRET="generate-a-long-random-string-here"
ADMIN_EMAIL="admin@toyingidea.com"
ADMIN_PASSWORD="change-me"
# ADMIN_PASSWORD_HASH="$2a$10$..."   # npm run hash:admin -- "your-password"

VITE_API_BASE=""

# ---- Shopify headless (required for catalog + checkout) ----
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
VITE_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
VITE_SHOPIFY_STOREFRONT_TOKEN=""
VITE_SHOPIFY_API_VERSION="2025-01"
PUBLIC_SITE_URL="https://toying-idea.vercel.app"

# ---- Shopify Admin (order tracking) ----
# Option A (legacy custom app): permanent Admin token
SHOPIFY_ADMIN_TOKEN="shpat_xxxxxxxx"

# Option B (Dev Dashboard app): client credentials — preferred if you only have shpss_
# Client ID + Secret from app Settings. App must be installed with read_orders.
# SHOPIFY_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SHOPIFY_CLIENT_SECRET="shpss_xxxxxxxx"
SHOPIFY_API_VERSION="2025-01"
