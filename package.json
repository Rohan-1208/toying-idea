{
  "name": "website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vercel dev",
    "build": "tsc -b && tsc -p tsconfig.api.json --noEmit && vite build",
    "typecheck": "tsc -b && tsc -p tsconfig.api.json --noEmit",
    "lint": "oxlint",
    "preview": "vite preview",
    "init:db": "node --env-file=.env scripts/init-db.mjs",
    "check:db": "node --env-file=.env scripts/check-db.mjs",
    "export:images": "node --env-file=.env scripts/export-gridfs-images.mjs",
    "apply:image-urls": "node --env-file=.env scripts/apply-image-urls.mjs",
    "set:bundle-pricing": "node --env-file=.env scripts/set-bundle-pricing.mjs",
    "seed:reviews": "node --env-file=.env scripts/seed-reviews.mjs",
    "hash:admin": "node scripts/hash-admin.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vercel/node": "^5.8.19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.1",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vercel": "^54.15.1",
    "vite": "^8.1.0"
  }
}
