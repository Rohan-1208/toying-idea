{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth?action=login"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth?action=me"
    },
    {
      "source": "/api/products/:id",
      "destination": "/api/products?id=:id"
    },
    {
      "source": "/api/orders/:id",
      "destination": "/api/orders?id=:id"
    },
    {
      "source": "/((?!api/|src/|@|node_modules/|assets/)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
